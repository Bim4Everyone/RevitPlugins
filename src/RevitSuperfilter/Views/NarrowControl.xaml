<UserControl
    x:Class="RevitSuperfilter.Views.NarrowControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:RevitSuperfilter.Views"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:me="clr-namespace:dosymep.WpfCore.MarkupExtensions;assembly=dosymep.WpfCore"
    xmlns:vms="clr-namespace:RevitSuperfilter.ViewModels"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviours="clr-namespace:RevitSuperfilter.Behaviours"

    mc:Ignorable="d"
    d:DesignHeight="500" d:DesignWidth="400"
    d:DataContext="{d:DesignInstance vms:MainViewModel, IsDesignTimeCreatable=False}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../ViewTemplates/TreeViewItemTemplate.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="8 4"
            CornerRadius="6"
            Background="{DynamicResource CardBackground}">
            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ui:AutoSuggestBox
                    Grid.Row="0"
                    Margin="8 4"
                    PlaceholderText="{me:LocalizationSource WideControl.SearchElements}" />

                <TreeView
                    Grid.Row="1"
                    x:Name="_categories"
                    Margin="8 4"
                    ItemsSource="{Binding SuperfilterService.CategoriesViewModel.Categories}">

                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="SelectedItemChanged">
                            <b:InvokeCommandAction
                                Command="{Binding
                            ElementName=_categories,
                            Path=SelectedItem.LoadParamsCommand}" />
                        </b:EventTrigger>
                    </b:Interaction.Triggers>

                </TreeView>

            </Grid>
        </Border>

        <DockPanel
            Grid.Row="1"
            Margin="8 4"
            LastChildFill="True">

            <ui:Button
                Width="80"
                Margin="5 0 0 0"
                DockPanel.Dock="Right"
                Content="{me:LocalizationSource MainWindow.ButtonShow}" />

            <ComboBox />
        </DockPanel>

        <DockPanel
            Grid.Row="2"
            Margin="8 4"
            LastChildFill="True">

            <ui:Button
                Width="80"
                DockPanel.Dock="Right"
                Content="{me:LocalizationSource MainWindow.ButtonIsolate}" />

            <ui:Button
                Width="80"
                Margin="5 0"
                DockPanel.Dock="Right"
                Content="{me:LocalizationSource MainWindow.ButtonSelect}" />

            <ui:TextBlock
                Foreground="Orange"
                VerticalAlignment="Center"
                HorizontalAlignment="Right"
                Text="{Binding ErrorText}" />
        </DockPanel>
    </Grid>
</UserControl>