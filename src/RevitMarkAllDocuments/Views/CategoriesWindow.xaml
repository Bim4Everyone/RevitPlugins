<core:WpfUIPlatformWindow
    x:Class="RevitMarkAllDocuments.Views.CategoriesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    
    xmlns:base="clr-namespace:dosymep.WPF.Views"
    xmlns:local="clr-namespace:RevitMarkAllDocuments.Views"
    xmlns:vms="clr-namespace:RevitMarkAllDocuments.ViewModels"
    xmlns:pages="clr-namespace:RevitMarkAllDocuments.Views"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:core="clr-namespace:dosymep.WpfUI.Core"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:me="clr-namespace:dosymep.WpfCore.MarkupExtensions;assembly=dosymep.WpfCore"
    
    mc:Ignorable="d"
    Title="{me:LocalizationSource MainWindow.Title}"
    
    Height="700"
    Width="500"
    
    MinHeight="700"
    MinWidth="500"
    d:DataContext="{d:DesignInstance vms:CategoriesWindowVM, IsDesignTimeCreatable=False}">

    <core:WpfUIPlatformWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </core:WpfUIPlatformWindow.Resources>

    <b:Interaction.Triggers>
        <b:EventTrigger
            EventName="Loaded">
            <b:InvokeCommandAction
                Command="{Binding LoadViewCommand}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition />
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="{me:LocalizationSource CategoriesWindow.Title}" />

        <Border
            Grid.Row="1"
            Margin="14,4"
            Style="{StaticResource CustomBorder}">
            <StackPanel>
                <TextBlock
                    Text="{me:LocalizationSource CategoriesWindow.SelectCategory}"
                    Margin="4,8" />
                <ui:AutoSuggestBox
                    Margin="0,0,0,8"
                    DockPanel.Dock="Top"
                    Icon="{ui:SymbolIcon Search24}"
                    Text="{Binding SearchText, Mode=TwoWay}"
                    PlaceholderText="{me:LocalizationSource CategoriesWindow.SearchText}">
                    <i:Interaction.Triggers>
                        <i:EventTrigger
                            EventName="TextChanged">
                            <i:InvokeCommandAction
                                Command="{Binding SearchCommand}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </ui:AutoSuggestBox>
            </StackPanel>
        </Border>
        
        <Border
            Grid.Row="2"
            Margin="14,4"
            Style="{StaticResource CustomBorder}">
            <ListBox
                ItemsSource="{Binding FilteredCategories}"
                SelectedItem="{Binding SelectedCategory}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock
                            Text="{Binding Name}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border
            Grid.Row="3"
            Margin="14,4"
            Style="{StaticResource CustomBorder}">
            <CheckBox
                Content="{me:LocalizationSource CategoriesWindow.MarkTypes}"
                IsChecked="{Binding IsMarkForTypes}"/>
        </Border>

        <StackPanel
            Grid.Row="4"
            Orientation="Horizontal"
            HorizontalAlignment="Right">
            <ui:TextBlock
                Margin="10"
                Foreground="Orange"
                VerticalAlignment="Center"
                Text="{Binding ErrorText}" />
            <ui:Button
                Margin="10"
                Width="80"
                Appearance="Info"
                Content="{me:LocalizationSource MainWindow.ButtonOk}"
                Click="ButtonOk_Click"
                Command="{Binding AcceptViewCommand}" />
            <ui:Button
                Margin="10"
                Width="80"
                Content="{me:LocalizationSource MainWindow.ButtonCancel}"
                IsCancel="True"
                Click="ButtonCancel_Click" />
        </StackPanel>
    </Grid>
</core:WpfUIPlatformWindow>
