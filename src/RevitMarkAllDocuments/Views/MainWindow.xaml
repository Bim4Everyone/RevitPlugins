<core:WpfUIPlatformWindow
    x:Class="RevitMarkAllDocuments.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:base="clr-namespace:dosymep.WPF.Views"
    xmlns:local="clr-namespace:RevitMarkAllDocuments.Views"
    xmlns:vms="clr-namespace:RevitMarkAllDocuments.ViewModels"
    xmlns:pages="clr-namespace:RevitMarkAllDocuments.Views"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:core="clr-namespace:dosymep.WpfUI.Core"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:me="clr-namespace:dosymep.WpfCore.MarkupExtensions;assembly=dosymep.WpfCore"
   
    mc:Ignorable="d"
    Title="{me:LocalizationSource MainWindow.Title}"
    
    Height="500"
    Width="1000"
    
    MinHeight="500"
    MinWidth="1000"
   
    d:DataContext="{d:DesignInstance vms:MainViewModel, IsDesignTimeCreatable=False}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadViewCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <ui:TitleBar
            Grid.Row="0"
            Title="{me:LocalizationSource MainWindow.Title}" />

        <ui:NavigationView
            Grid.Row="1"
            x:Name="_rootNavigationView"
            FrameMargin="0"
            OpenPaneLength="200"
            IsPaneOpen="True"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsPaneVisible="True"
            IsPaneToggleVisible="True"
            PaneTitle="{me:LocalizationSource MainWindow.Settings}"
            BreadcrumbBar="{Binding ElementName=_breadcrumbBar}">

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem
                    Content="{me:LocalizationSource MainWindow.DocumentsPage}"
                    Icon="{ui:SymbolIcon WindowBulletList20}"
                    TargetPageType="{x:Type pages:DocumentsPage}">
                </ui:NavigationViewItem>
                <ui:NavigationViewItem
                    Content="{me:LocalizationSource MainWindow.FilterPage}"
                    Icon="{ui:SymbolIcon TextBulletListSquare20}"
                    TargetPageType="{x:Type pages:FilterPage}">
                </ui:NavigationViewItem>
                <ui:NavigationViewItem
                    Content="{me:LocalizationSource MainWindow.SortPage}"
                    Icon="{ui:SymbolIcon NumberSymbolSquare20}"
                    TargetPageType="{x:Type pages:SortPage}" />
                <ui:NavigationViewItem
                    Content="{me:LocalizationSource MainWindow.MarkPage}"
                    Icon="{ui:SymbolIcon NumberSymbolSquare20}"
                    TargetPageType="{x:Type pages:MarkSettingsPage}" />
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.PaneFooter>
                <StackPanel>                    
                    <TextBlock
                        Margin="24,4"
                        TextWrapping="Wrap"
                        FontWeight="DemiBold"
                        Text="{me:LocalizationSource MainWindow.SelectedCategory}" />                
                    <TextBlock
                        Margin="24,0"
                        TextWrapping="Wrap"
                        Text="{Binding SelectedCategoryName}" />
                </StackPanel>
            </ui:NavigationView.PaneFooter>
        </ui:NavigationView>

        <StackPanel
            Grid.Row="2"
            Orientation="Horizontal"
            HorizontalAlignment="Right">

            <ui:TextBlock
                Margin="10"
                Foreground="Orange"
                VerticalAlignment="Center"
                Text="{Binding ErrorText}" />

            <ui:Button
                Margin="10"
                Width="80"
                Appearance="Info"
                Content="{me:LocalizationSource MainWindow.ButtonOk}"
                Click="ButtonOk_Click"
                Command="{Binding AcceptViewCommand}" />

            <ui:Button
                Margin="10"
                Width="80"
                Content="{me:LocalizationSource MainWindow.ButtonCancel}"
                IsCancel="True"
                Click="ButtonCancel_Click" />
        </StackPanel>
    </Grid>
</core:WpfUIPlatformWindow>
