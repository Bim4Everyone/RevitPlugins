<core:WpfUIPlatformWindow
    x:Class="RevitMarkAllDocuments.Views.MarkListWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:base="clr-namespace:dosymep.WPF.Views"
    xmlns:local="clr-namespace:RevitMarkAllDocuments.Views"
    xmlns:vms="clr-namespace:RevitMarkAllDocuments.ViewModels"
    xmlns:pages="clr-namespace:RevitMarkAllDocuments.Views"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:core="clr-namespace:dosymep.WpfUI.Core"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:me="clr-namespace:dosymep.WpfCore.MarkupExtensions;assembly=dosymep.WpfCore"
    mc:Ignorable="d"
    
    Title="{me:LocalizationSource MainWindow.Title}"
    
    Height="500"
    Width="1000"
    
    MinHeight="500"
    MinWidth="1000">

    <core:WpfUIPlatformWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </core:WpfUIPlatformWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="{me:LocalizationSource MainWindow.Title}" />

        <Border
            Grid.Row="1"
            Margin="14,4"
            Style="{StaticResource CustomBorder}">
            <StackPanel
                Orientation="Vertical">
                <TextBlock
                    Text="{me:LocalizationSource MarkList.Description}"/>

                <StackPanel
                    Orientation="Horizontal">                    
                    <TextBlock
                        Text="{me:LocalizationSource MarkList.ParameterName}" />                    
                    <TextBlock
                        Margin="5,0,0,0"
                        Text="{Binding ParameterName}" />
                </StackPanel>
            </StackPanel>            
        </Border>

        <Border
            Grid.Row="2"
            Margin="14,4"
            Style="{StaticResource CustomBorder}">
            <ui:DataGrid
                ItemsSource="{Binding Path=MarkedElements}"
                Style="{StaticResource  CustomResizableDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding Path=Id}"
                        IsReadOnly="True">
                        <DataGridTextColumn.Header>
                            <TextBlock
                                TextAlignment="Center"
                                Text="{me:LocalizationSource MarkList.HeaderId}" />
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        Width="250"
                        Binding="{Binding Path=Name}"
                        IsReadOnly="True">
                        <DataGridTextColumn.Header>
                            <TextBlock
                                TextAlignment="Center"
                                Text="{me:LocalizationSource MarkList.HeaderName}" />
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding Path=MarkValue}"
                        IsReadOnly="True">
                        <DataGridTextColumn.Header>
                            <TextBlock
                                TextAlignment="Center"
                                Text="{me:LocalizationSource MarkList.HeaderValue}" />
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        Width="300"
                        Binding="{Binding Path=Status}"
                        IsReadOnly="True">
                        <DataGridTextColumn.Header>
                            <TextBlock
                                TextAlignment="Center"
                                Text="{me:LocalizationSource MarkList.HeaderStatus}" />
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </ui:DataGrid>
        </Border>

        <StackPanel
            Grid.Row="3"
            Orientation="Horizontal"
            HorizontalAlignment="Right">

            <ui:TextBlock
                Margin="10"
                Foreground="Orange"
                VerticalAlignment="Center"
                Text="{Binding ErrorText}" />

            <ui:Button
                Margin="10"
                Width="80"
                Appearance="Info"
                Content="{me:LocalizationSource MainWindow.ButtonOk}"
                Click="ButtonOk_Click"
                Command="{Binding MarkElementsCommand}" />

            <ui:Button
                Margin="10"
                Width="80"
                Content="{me:LocalizationSource MainWindow.ButtonCancel}"
                IsCancel="True"
                Click="ButtonCancel_Click" />
        </StackPanel>
    </Grid>
</core:WpfUIPlatformWindow>
