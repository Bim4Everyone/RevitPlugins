<core:WpfUIPlatformWindow
    x:Class="RevitRemoveRoomTags.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    
    xmlns:base="clr-namespace:dosymep.WPF.Views"
    xmlns:local="clr-namespace:RevitRemoveRoomTags.Views"
    xmlns:vms="clr-namespace:RevitRemoveRoomTags.ViewModels"
    
    xmlns:core="clr-namespace:dosymep.WpfUI.Core"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:me="clr-namespace:dosymep.WpfCore.MarkupExtensions;assembly=dosymep.WpfCore"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    
    mc:Ignorable="d"
    WindowStartupLocation="CenterOwner"
    
    MinHeight="450" MinWidth="680"
    Height="450" Width="680"
    
    Validation.Error="Window_Error"
    d:DataContext="{d:DesignInstance vms:MainViewModel, IsDesignTimeCreatable=False}">

    <i:Interaction.Triggers>
        <i:EventTrigger
            EventName="Loaded">
            <i:InvokeCommandAction
                Command="{Binding LoadViewCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ui:TextBlock
                x:Key="SelectTagsColumnHeader"
                Text="{me:LocalizationSource MainWindow.SelectTagsColumn}" />
            <ui:TextBlock
                x:Key="SelectedCountColumnHeader"
                Text="{me:LocalizationSource MainWindow.SelectedCountColumn}" />
            <ui:TextBlock
                x:Key="XOffsetColumnHeader"
                Text="{me:LocalizationSource MainWindow.XOffsetColumn}" />
            <ui:TextBlock
                x:Key="YOffsetColumnHeader"
                Text="{me:LocalizationSource MainWindow.YOffsetColumn}" />
            <ui:TextBlock
                x:Key="DeleteColumnHeader"
                Text="{me:LocalizationSource MainWindow.DeleteColumn}" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="{me:LocalizationSource MainWindow.Title}" />

        <Border
            Grid.Row="1"
            Margin="10 0 10 5"
            Style="{StaticResource CustomBorder}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal">
                    <ui:TextBlock
                        Margin="10 5 5 5"
                        VerticalAlignment="Center"
                        Text="{me:LocalizationSource MainWindow.SelectedViewsPrefix}" />

                    <ui:TextBlock
                        Margin="5"
                        VerticalAlignment="Center"
                        Text="{Binding Path=SelectedViews.Count}" />
                </StackPanel>

                <CheckBox
                    Grid.Column="1"
                    Margin="5"
                    HorizontalAlignment="Right"
                    VerticalContentAlignment="Center"
                    Content="{me:LocalizationSource MainWindow.OpenSelectedViews}"
                    IsChecked="{Binding Path=NeedOpenSelectedViews}" />
            </Grid>
        </Border>

        <Border
            Grid.Row="2"
            Margin="10 5 10 0"
            Style="{StaticResource CustomBorder}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ui:TextBlock
                    Grid.Row="0"
                    Margin="10 5 5 5"
                    VerticalAlignment="Center"
                    Text="{me:LocalizationSource MainWindow.TasksLabel}" />

                <ui:DataGrid
                    Grid.Row="1"
                    Margin="0"
                    Style="{StaticResource CustomResizableDataGridStyle}"
                    ItemsSource="{Binding Path=RoomTagTasks, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                    SelectedItem="{Binding Path=SelectedRoomTagTask}"
                    SelectionMode="Single"
                    ScrollViewer.VerticalScrollBarVisibility="Visible"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    AutoGenerateColumns="False">

                    <DataGrid.Columns>
                        <!-- Колонка с кнопкой выбора марок -->
                        <DataGridTemplateColumn
                            Width="130"
                            MinWidth="130"
                            Header="{StaticResource SelectTagsColumnHeader}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ui:Button
                                        Margin="5"
                                        HorizontalAlignment="Stretch"
                                        VerticalContentAlignment="Center"
                                        Icon="{ui:SymbolIcon Cursor24}"
                                        Command="{Binding 
                                            Path=DataContext.SelectRoomTagsCommand, 
                                            RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Колонка с количеством выбранных марок -->
                        <DataGridTemplateColumn
                            Width="90"
                            MinWidth="90"
                            Header="{StaticResource SelectedCountColumnHeader}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Width="50"
                                        TextAlignment="Center"
                                        Text="{Binding RoomTags.Count}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Колонка для смещения по X -->
                        <DataGridTemplateColumn
                            Width="150"
                            MinWidth="150"
                            Header="{StaticResource XOffsetColumnHeader}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox
                                        Margin="5"
                                        HorizontalAlignment="Stretch"
                                        VerticalContentAlignment="Center"
                                        Validation.ErrorTemplate="{StaticResource ValidationFailed}"
                                        Text="{Binding 
                                            Path=XOffsetAsStr,
                                            UpdateSourceTrigger=PropertyChanged, 
                                            ValidatesOnDataErrors=True, 
                                            NotifyOnValidationError=True}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Колонка для смещения по Y -->
                        <DataGridTemplateColumn
                            Width="150"
                            MinWidth="150"
                            Header="{StaticResource YOffsetColumnHeader}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox
                                        Margin="5"
                                        HorizontalAlignment="Stretch"
                                        VerticalContentAlignment="Center"
                                        Validation.ErrorTemplate="{StaticResource ValidationFailed}"
                                        Text="{Binding 
                                            Path=YOffsetAsStr,
                                            UpdateSourceTrigger=PropertyChanged, 
                                            ValidatesOnDataErrors=True, 
                                            NotifyOnValidationError=True}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Колонка с чекбоксом удаления -->
                        <DataGridTemplateColumn
                            Width="90"
                            MinWidth="90"
                            Header="{StaticResource DeleteColumnHeader}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox
                                        HorizontalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        IsChecked="{Binding Path=RemoveTags}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </ui:DataGrid>

                <StackPanel
                    Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

                    <ui:Button
                        Margin="5"
                        Width="150"
                        ToolTip="{me:LocalizationSource MainWindow.AddTaskToolTip}"
                        Content="{me:LocalizationSource MainWindow.AddTaskButton}"
                        Command="{Binding Path=AddTaskCommand}" />

                    <ui:Button
                        Margin="5"
                        Width="150"
                        ToolTip="{me:LocalizationSource MainWindow.DeleteTaskToolTip}"
                        Content="{me:LocalizationSource MainWindow.DeleteTaskButton}"
                        Command="{Binding Path=DeleteTaskCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        
        <StackPanel
            Grid.Row="3"
            Orientation="Horizontal"
            HorizontalAlignment="Right">
            <ui:TextBlock
                Margin="10"
                Foreground="Orange"
                VerticalAlignment="Center"
                Text="{Binding ErrorText}" />

            <ui:Button
                Margin="10"
                Width="80"
                Content="{me:LocalizationSource MainWindow.ButtonOk}"
                Click="ButtonOk_Click"
                Appearance="Info"
                Command="{Binding Path=AcceptViewCommand}" />

            <ui:Button
                Margin="10"
                Width="80"
                Content="{me:LocalizationSource MainWindow.ButtonCancel}"
                Click="ButtonCancel_Click">
            </ui:Button>
        </StackPanel>
    </Grid>
</core:WpfUIPlatformWindow>