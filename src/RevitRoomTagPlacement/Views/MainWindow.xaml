<core:WpfUIPlatformWindow
    x:Class="RevitRoomTagPlacement.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:base="clr-namespace:dosymep.WPF.Views"    
    xmlns:local="clr-namespace:RevitRoomTagPlacement.Views"
    xmlns:vms="clr-namespace:RevitRoomTagPlacement.ViewModels"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:core="clr-namespace:dosymep.WpfUI.Core"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:me="clr-namespace:dosymep.WpfCore.MarkupExtensions;assembly=dosymep.WpfCore"
    
    mc:Ignorable="d"
    WindowStartupLocation="CenterOwner"
    
    Title="MainWindow"
    Width="700" Height="800"
    MinWidth="700" MinHeight="800"

    d:DataContext="{d:DesignInstance vms:MainViewModel, IsDesignTimeCreatable=False}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary  Source="Styles/RadioButtonStyle.xaml"/>
                <ResourceDictionary  Source="Styles/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>            
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>    

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            VerticalAlignment="Center"
            Title="{me:LocalizationSource MainWindow.Title}" />

        <Border
            Grid.Row="1"
            Margin="14,0,14,4"
            Style="{StaticResource CustomBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <ComboBox
                    Margin="0,0,0,7"
                    ItemsSource="{Binding RevitViewModels}"
                    DisplayMemberPath="Name"
                    SelectedItem="{Binding RevitViewModel}"/>
                <Border
                    Grid.Row="1"
                    Style="{StaticResource CustomBorder}">
                    <ui:ListView
                        x:Name="RoomGroups"
                        SelectionMode="Extended"
                        DataContext="{Binding RevitViewModel}"
                        ItemsSource="{Binding RoomGroups}">
                        <ui:ListView.ItemTemplate>
                            <DataTemplate>
                                <CheckBox 
                                    Content="{Binding Name}"
                                    Checked="CheckBox_Checked"
                                    Unchecked="CheckBox_Unchecked"
                                    IsChecked="{Binding IsChecked}"/>
                            </DataTemplate>
                        </ui:ListView.ItemTemplate>
                    </ui:ListView>
                </Border>
            </Grid>
        </Border>

        <Border
            Grid.Row="2"
            Margin="14,0,14,4"
            Style="{StaticResource CustomBorder}">
            <StackPanel>
                <DockPanel
                    Margin="0,0,0,7">
                    <TextBlock
                        DockPanel.Dock="Left"
                        Width="160"
                        VerticalAlignment="Center"
                        Text="{me:LocalizationSource MainWindow.TagFamily}"/>
                    <ComboBox
                        DataContext="{Binding RevitViewModel}"
                        ItemsSource="{Binding TagFamilies}"
                        DisplayMemberPath="Name"
                        SelectedItem="{Binding SelectedTagType}"/>
                </DockPanel>

                <DockPanel                    
                    DataContext="{Binding RevitViewModel}">
                    <TextBlock
                        Margin="0,4,0,0"
                        DockPanel.Dock="Left"
                        Width="160"
                        Text="{me:LocalizationSource MainWindow.WayOfPlacement}"/>
                    <StackPanel> 
                        <RadioButton
                            GroupName="PlacementWays"
                            Content="{me:LocalizationSource MainWindow.EveryRoom}" 
                            IsChecked="{Binding IsEveryRoom}"/>
                        <RadioButton
                            GroupName="PlacementWays"
                            Content="{me:LocalizationSource MainWindow.OneRoomPerGroupMaxArea}" 
                            IsChecked="{Binding IsOneRoomPerGroupRandom}"/>
                        <RadioButton
                            x:Name="_placementWay"
                            GroupName="PlacementWays"
                            Content="{me:LocalizationSource MainWindow.OneRoomPerGroup}" 
                            IsChecked="{Binding IsOneRoomPerGroupByName}"/>
                    </StackPanel>
                </DockPanel>

                <DockPanel
                    Margin="0,7,0,0"
                    DataContext="{Binding RevitViewModel}"
                    Visibility="{Binding ElementName=_placementWay,
                                Path=IsChecked, 
                                Converter={StaticResource BoolToVis}}"
                    d:Visibility="Visible">
                    <TextBlock 
                        DockPanel.Dock="Left"
                        Width="160"
                        VerticalAlignment="Center"
                        Text="{me:LocalizationSource MainWindow.RoomName}"/>
                    <ComboBox
                        ItemsSource="{Binding RoomNames}"
                        SelectedItem="{Binding SelectedRoomName}"/>
                </DockPanel>
            </StackPanel>
        </Border>

        <Border
            Grid.Row="3"
            Margin="14,0,14,0"
            Style="{StaticResource CustomBorder}">
            <StackPanel>
                <DockPanel
                    Margin="0,0,0,7"
                    HorizontalAlignment="Left"
                    DataContext="{Binding RevitViewModel}">
                    <TextBlock
                        VerticalAlignment="Top"
                        Width="160"
                        Text="{me:LocalizationSource MainWindow.TagPosition}" />
                    <UniformGrid
                        Height="90"
                        Width="90"
                        VerticalAlignment="Top"   
                        Rows="3"
                        Columns="3">
                        <UniformGrid.Resources>
                            <Style 
                                BasedOn="{StaticResource SquareRadioButton}"
                                TargetType="{x:Type RadioButton}"/>
                        </UniformGrid.Resources>
                        <RadioButton
                            GroupName="PlacementPosition"
                            IsChecked="{Binding IsPositionLeftTop}"/>
                        <RadioButton
                            GroupName="PlacementPosition"
                            IsChecked="{Binding IsPositionCenterTop}"/>
                        <RadioButton
                            GroupName="PlacementPosition"
                            IsChecked="{Binding IsPositionRightTop}"/>
                        <RadioButton
                            GroupName="PlacementPosition"
                            IsChecked="{Binding IsPositionLeftCenter}"/>
                        <RadioButton
                            GroupName="PlacementPosition"
                            IsChecked="{Binding IsPositionCenterCenter}"/>
                        <RadioButton
                            GroupName="PlacementPosition"
                            IsChecked="{Binding IsPositionRightCenter}"/>
                        <RadioButton
                            GroupName="PlacementPosition"
                            IsChecked="{Binding IsPositionLeftBottom}"/>
                        <RadioButton
                            GroupName="PlacementPosition"
                            IsChecked="{Binding IsPositionCenterBottom}"/>
                        <RadioButton
                            GroupName="PlacementPosition"
                            IsChecked="{Binding IsPositionRightBottom}"/>
                    </UniformGrid>            
                </DockPanel>

                <DockPanel>
                    <TextBlock 
                        DockPanel.Dock="Left"
                        Width="160"
                        VerticalAlignment="Center"
                        Text="{me:LocalizationSource MainWindow.Indent}"/>
                    <TextBox
                        PreviewTextInput="IndentValidation"
                        PreviewKeyDown="TextBox_PreviewKeyDown"
                        DataContext="{Binding RevitViewModel}"
                        Text="{Binding Indent}"/>
                </DockPanel>
            </StackPanel>
        </Border>
    
        <StackPanel
            Grid.Row="4"
            Orientation="Horizontal"
            HorizontalAlignment="Right">
            <TextBlock
                Margin="10"
                Foreground="Orange"
                VerticalAlignment="Center"
                DataContext="{Binding RevitViewModel}"
                Text="{Binding ErrorText}" />
            <ui:Button
                Margin="10"
                Width="80"
                Appearance="Info"
                IsDefault="True"
                Content="{me:LocalizationSource MainWindow.Ok}"
                Click="ButtonOk_Click"
                DataContext="{Binding RevitViewModel}"
                Command="{Binding PlaceTagsCommand}" />
            <ui:Button
                Margin="10"
                Width="80"
                Content="{me:LocalizationSource MainWindow.Cancel}"
                IsCancel="True"
                Click="ButtonCancel_Click" />
        </StackPanel>
    </Grid>
</core:WpfUIPlatformWindow>
