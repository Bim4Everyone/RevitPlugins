<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <system:String
        x:Key="Plugin.Title">Load Areas</system:String>

    <system:String
        x:Key="Pick.Floor">Select a floor slab</system:String>
    <system:String
        x:Key="Pick.Pylons">Select pylons (structural columns)</system:String>
    <system:String
        x:Key="Pick.Walls">Select walls below the slab (press ESC to skip)</system:String>

    <system:String
        x:Key="Transaction.DrawLoadAreas">BIM: Load Areas</system:String>

    <system:String
        x:Key="Error.ViewNotSupported">The active view does not support creation of load areas. Open a plan, section, or elevation view.</system:String>
    <system:String
        x:Key="Error.FilledRegionTypeNotFound">No filled region type was found in the project.</system:String>

</ResourceDictionary>