<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Style
        TargetType="Border"
        x:Key="CustomBorder">
        <Setter
            Property="Padding"
            Value="14 8 14 8" />
        <Setter
            Property="VerticalAlignment"
            Value="Stretch" />
        <Setter
            Property="HorizontalAlignment"
            Value="Stretch" />
        <Setter
            Property="SnapsToDevicePixels"
            Value="True" />
        <Setter
            Property="OverridesDefaultStyle"
            Value="True" />
        <Setter
            Property="ScrollViewer.HorizontalScrollBarVisibility"
            Value="Auto" />
        <Setter
            Property="ScrollViewer.VerticalScrollBarVisibility"
            Value="Disabled" />
        <Setter
            Property="Background"
            Value="{DynamicResource CardBackground}" />
        <Setter
            Property="BorderBrush"
            Value="{DynamicResource CardBorderBrush}" />
        <Setter
            Property="BorderThickness"
            Value="{DynamicResource CardControlBorderThemeThickness}" />
        <Setter
            Property="FocusVisualStyle"
            Value="{DynamicResource DefaultControlFocusVisualStyle}" />
        <Setter
            Property="CornerRadius"
            Value="{DynamicResource ControlCornerRadius}" />
    </Style>
    <Style
        x:Key="CustomGroupHeaderStyle"
        TargetType="{x:Type GroupItem}">
        <Setter
            Property="Template">
            <Setter.Value>
                <ControlTemplate
                    TargetType="{x:Type GroupItem}">
                    <ui:CardExpander
                        IsExpanded="False">
                        <ui:CardExpander.Header>
                            <DockPanel
                                Margin="0 0 14 0"
                                HorizontalAlignment="Stretch">
                                <TextBlock
                                    Text="{Binding Path=Name}" />
                                <DockPanel
                                    HorizontalAlignment="Right">
                                    <TextBlock
                                        Text="{Binding Path=ItemCount}" />
                                </DockPanel>
                            </DockPanel>
                        </ui:CardExpander.Header>
                        <ui:CardExpander.Content>
                            <ItemsPresenter />
                        </ui:CardExpander.Content>
                    </ui:CardExpander>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>