<core:WpfUIPlatformWindow
    x:Class="RevitPunchingRebar.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:base="clr-namespace:dosymep.WPF.Views"
    xmlns:local="clr-namespace:RevitPunchingRebar.Views"
    xmlns:vms="clr-namespace:RevitPunchingRebar.ViewModels"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:core="clr-namespace:dosymep.WpfUI.Core"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:me="clr-namespace:dosymep.WpfCore.MarkupExtensions;assembly=dosymep.WpfCore"
   
    mc:Ignorable="d"
    Title="Расстановка каркасов"
    
    Height="600"
    Width="700"
    
    MinHeight="600"
    MinWidth="700"
   
    d:DataContext="{d:DesignInstance vms:MainViewModel, IsDesignTimeCreatable=False}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadViewCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Window.Resources>
        <Style TargetType="Border" x:Key="uiBorder">
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="14 8 14 8"/>
            <Setter Property="Margin" Value="8 0 8 0"/>
        </Style>
        
        <Style TargetType="ui:TextBlock" x:Key="groupName">
            <Setter Property="Margin" Value="8 8 0 8"/>
        </Style>

        <Style TargetType="ui:TextBlock" x:Key="itemName">
            <Setter Property="Height" Value="30"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="itemCB">
            <Setter Property="Margin" Value="0 0 0 10"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="Расстановка каркасов"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel 
                Grid.Column="0"
                Orientation="Vertical">
                
                <ui:TextBlock
                    Style="{StaticResource groupName}"
                    Text="Общие настройки"/>

                <Border Style="{StaticResource uiBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                        <ui:TextBlock 
                            Grid.Column="0"
                            Grid.Row="0"
                            Style="{StaticResource itemName}"
                            Text="Пилоны из модели"/>

                        <ui:TextBlock
                            Grid.Column="0"
                            Grid.Row="1"
                            Style="{StaticResource itemName}"
                            Text="Пилоны из связи"/>

                        <ui:TextBlock
                            Grid.Column="0"
                            Grid.Row="2"
                            Style="{StaticResource itemName}"
                            Text="Пилонов выбрано:"/>

                        <ui:TextBlock
                            Grid.Column="0"
                            Grid.Row="3"
                            Style="{StaticResource itemName}"
                            Text="Плита"/>

                        <ui:TextBlock
                            Grid.Column="0"
                            Grid.Row="4"
                            Style="{StaticResource itemName}"
                            Text="Плита выбрана:"/>



                        <ui:Button
                            Grid.Column="1"
                            Grid.Row="0"
                            Content="Выбрать"
                            Width="150"
                            Height="30"
                            Command="{Binding SelectPylonsFromModelCommand}"/>

                        <ui:Button
                            Grid.Column="1"
                            Grid.Row="1"
                            Content="Выбрать"
                            Width="150"
                            Height="30"
                            Command="{Binding SelectPylonsFromLinkCommand}"/>

                        <TextBlock
                            Grid.Column="1"
                            Grid.Row="2"
                            Text="{Binding SelectedPylonsCount}"/>

                        <ui:Button
                            Grid.Column="1"
                            Grid.Row="3"
                            Content="Выбрать"
                            Width="150"
                            Height="30"
                            Command="{Binding SelectSlabCommand}"/>

                        <TextBlock
                            Grid.Column="1"
                            Grid.Row="4"
                            Text="{Binding IsSlabSelected}"/>
                    </Grid>
                </Border>

                <ui:TextBlock
                    Style="{StaticResource groupName}"
                    Text="Арматура плиты"/>

                <Border Style="{StaticResource uiBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                        </Grid.RowDefinitions>

                        <ui:TextBlock
                            Grid.Column="0"
                            Grid.Row="0"
                            Style="{StaticResource itemName}"
                            Text="Диаметр стержней, мм"/>

                        <RadioButton
                            Grid.Column="0"
                            Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Content="Использовать защ. слой из плиты"
                            GroupName="1"
                            IsChecked="{Binding IsRebarCoverFromSlab}"/>

                        <RadioButton
                            Grid.Column="0"
                            Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Content="Ввести защ. слой вручную"
                            GroupName="1"
                            IsChecked="{Binding IsRebarCoverFromUser}"/>

                        <ui:TextBlock
                            Grid.Column="0"
                            Grid.Row="3"
                            Style="{StaticResource itemName}"
                            Text="Защ. слой сверху, мм"
                            IsEnabled="{Binding IsControlEnabled}"/>

                        <ui:TextBlock
                            Grid.Column="0"
                            Grid.Row="4"
                            Style="{StaticResource itemName}"
                            Text="Защ. слой снизу, мм"
                            IsEnabled="{Binding IsControlEnabled}"/>





                        <ComboBox
                            Grid.Column="1"
                            Grid.Row="0"
                            ItemsSource="{Binding RebarDiameters}"
                            SelectedItem="{Binding SelectedSlabRebarDiameter}"/>
                        
                        <ui:TextBox
                            Grid.Column="1"
                            Grid.Row="3"
                            IsEnabled="{Binding IsControlEnabled}"
                            Text="{Binding RebarCoverTop}"/>

                        <ui:TextBox
                            Grid.Column="1"
                            Grid.Row="4"
                            IsEnabled="{Binding IsControlEnabled}"
                            Text="{Binding RebarCoverBottom}"/>
                    </Grid>
                </Border>



            </StackPanel>

            <StackPanel
                Grid.Column="1"
                Orientation="Vertical">
                
                <ui:TextBlock
                    Style="{StaticResource groupName}"
                    Text="Арматура каркасов"/>

                <Border Style="{StaticResource uiBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                        </Grid.RowDefinitions>

                        <ui:TextBlock
                            Grid.Column="0"
                            Grid.Row="0"
                            Style="{StaticResource itemName}"
                            Text="Имя семейства"/>

                        <ui:TextBlock
                            Grid.Column="0"
                            Grid.Row="1"
                            Style="{StaticResource itemName}"
                            Text="Имя типа"/>

                        <ui:TextBlock
                            Grid.Column="0"
                            Grid.Row="2"
                            Style="{StaticResource itemName}"
                            Text="Диаметр стержней, мм"/>

                        <ui:TextBlock
                            Grid.Column="0"
                            Grid.Row="3"
                            Style="{StaticResource itemName}"
                            Text="Класс стержней"/>

                        <ui:TextBlock
                            Grid.Column="0"
                            Grid.Row="4"
                            Style="{StaticResource itemName}"
                            Text="Шаг хомутов, мм"/>

                        <ui:TextBlock
                            Grid.Column="0"
                            Grid.Row="5"
                            Style="{StaticResource itemName}"
                            Text="Ширина каркаса, мм"/>



                        <ComboBox
                            Grid.Column="1"
                            Grid.Row="0"
                            ItemsSource="{Binding FamilyNames}"
                            SelectedItem="{Binding SelectedFamilyName}"/>
                        
                        <ComboBox
                            Grid.Column="1"
                            Grid.Row="1"
                            ItemsSource="{Binding FamilyTypes}"
                            SelectedItem="{Binding SelectedFamilyType}"/>

                        <ComboBox
                            Grid.Column="1"
                            Grid.Row="2"
                            ItemsSource="{Binding RebarDiameters}"
                            SelectedItem="{Binding SelectedStirrupDiameter}"/>

                        <ComboBox
                            Grid.Column="1"
                            Grid.Row="3"
                            ItemsSource="{Binding RebarClasses}"
                            SelectedItem="{Binding SelectedRebarClass}"/>

                        <ui:TextBox
                            Grid.Column="1"
                            Grid.Row="4"
                            Text="{Binding StirrupStep}"/>
                        
                        <ui:TextBox
                            Grid.Column="1"
                            Grid.Row="5"
                            Text="{Binding FrameWidth}"/>

                    </Grid>
                </Border>
            </StackPanel>
        </Grid>

        <StackPanel
            Grid.Row="2"
            Orientation="Horizontal"
            HorizontalAlignment="Right">

            <ui:TextBlock
                Margin="10"
                Foreground="Orange"
                VerticalAlignment="Center"
                Text="{Binding ErrorText}" />

            <ui:Button
                Margin="10"
                Width="80"
                Appearance="Info"
                Content="{me:LocalizationSource MainWindow.ButtonOk}"
                Command="{Binding AcceptViewCommand}" />

            <ui:Button
                Margin="10"
                Width="80"
                Content="{me:LocalizationSource MainWindow.ButtonCancel}"
                Command="{Binding CancelViewCommand}" />
        </StackPanel>
    </Grid>
</core:WpfUIPlatformWindow>