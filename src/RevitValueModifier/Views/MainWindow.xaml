<core:WpfUIPlatformWindow
    x:Class="RevitValueModifier.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    
    xmlns:base="clr-namespace:dosymep.WPF.Views"
    xmlns:converters="clr-namespace:dosymep.WPF.Converters"
    xmlns:local="clr-namespace:RevitValueModifier.Views"
    xmlns:vms="clr-namespace:RevitValueModifier.ViewModels"
    
    xmlns:core="clr-namespace:dosymep.WpfUI.Core"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:me="clr-namespace:dosymep.WpfCore.MarkupExtensions;assembly=dosymep.WpfCore"
    
    mc:Ignorable="d"
    WindowStartupLocation="CenterOwner"
    
    x:Name="window"
    
    Height="400" Width="700"
    MinHeight="400" MinWidth="700"

    d:DataContext="{d:DesignInstance vms:MainViewModel, IsDesignTimeCreatable=False}">

    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <local:ParamTypeConverter 
                x:Key="paramTypeConverter" 
                LocalizationService="{Binding ElementName=window, Path=LocalizationService}"/>
            
            <ui:TextBlock
                x:Key="DataColumnRevitElementHeader"
                Text="{me:LocalizationSource ResourceKey=MainWindow.RevitElement}" />
            <ui:TextBlock
                x:Key="DataColumnElementParamValueHeader"
                Text="{me:LocalizationSource ResourceKey=MainWindow.ElementParamValue}" />
        </ResourceDictionary>
    </Window.Resources>
    
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction
                Command="{Binding LoadViewCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Title="{me:LocalizationSource MainWindow.Title}" />
        
        <Grid
            Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ui:TextBlock
                Grid.Column="0"
                Margin="10 5 5 5"
                VerticalAlignment="Center"
                Text="{me:LocalizationSource ResourceKey=MainWindow.SelectParamToRecord}"/>

            <ComboBox
                Grid.Column="1"
                Margin="5 5 10 5"
                IsEditable="True"
                StaysOpenOnEdit="True"
                ItemsSource="{Binding Path=CommonParamsForWrite}"
                SelectedItem="{Binding Path=SelectedCommonParam}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <ui:TextBlock>
                            <ui:TextBlock Text="{Binding Path=ParamName}"/>
                            <ui:TextBlock 
                                Foreground="DarkGray"
                                Text="{Binding
                                    Path=ParamTypeName,
                                    StringFormat=({0}),
                                    Converter={StaticResource paramTypeConverter}}"/>
                        </ui:TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <Grid
            Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="152*"/>
                <ColumnDefinition Width="73*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <ui:TextBlock
                Grid.Column="0"
                Margin="10,5,5,5"
                VerticalAlignment="Center"
                Text="{me:LocalizationSource ResourceKey=MainWindow.EnterParamValueMask}"/>

            <ui:TextBox 
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Margin="5,5,5,5"
                LostFocus="TextBox_LostFocus"
                Text="{Binding Path=ParamValueMask, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" >
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="TextChanged">
                        <i:InvokeCommandAction
                            Command="{Binding Path=ParamUpdateCommand}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </ui:TextBox>

            <ComboBox
                Grid.Column="3"
                Margin="5,5,5,5"
                ItemsSource="{Binding Path=CommonParamsForRead}"
                SelectedItem="{Binding Path=SelectedCommonParamForAdd}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <ui:TextBlock>
                            <ui:TextBlock Text="{Binding Path=ParamName}"/>
                            <ui:TextBlock 
                                Foreground="DarkGray"
                                Text="{Binding
                                    Path=ParamTypeName,
                                    StringFormat=({0}),
                                    Converter={StaticResource paramTypeConverter}}"/>
                        </ui:TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>

                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="SelectionChanged">
                        <i:InvokeCommandAction
                            Command="{Binding AddParamInMaskCommand}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </ComboBox>

            <ui:TextBlock
                Grid.Column="3"
                Margin="10,0,10,0"
                VerticalAlignment="Center"
                IsHitTestVisible="False"
                Text="{me:LocalizationSource ResourceKey=MainWindow.SelectedParamForAdd}"/>
        </Grid>


        <StackPanel
            Grid.Row="3"
            Orientation="Horizontal"
            FlowDirection="RightToLeft">
            <ui:TextBox 
                Margin="5"
                FlowDirection="LeftToRight"
                MinWidth="200"
                Text="{Binding Path=RevitElementsFilter, UpdateSourceTrigger=PropertyChanged}"/>

            <ui:TextBlock
                Margin="5"
                VerticalAlignment="Center"
                Text="{me:LocalizationSource ResourceKey=MainWindow.Filtration}"/>
        </StackPanel>
        
        
        <ui:DataGrid
            Grid.Row="4"
            Margin="5"
            Style="{StaticResource CustomResizableDataGridStyle}"
            ItemsSource="{Binding Path=RevitElementVMs, UpdateSourceTrigger=PropertyChanged}">
            <DataGrid.Columns>
                <DataGridTemplateColumn 
                    Width="450"
                    Header="{StaticResource DataColumnRevitElementHeader}"
                    IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock 
                                    VerticalAlignment="Center"
                                    Text="{Binding ElemName}"/>
                                <TextBlock 
                                    Margin="5"
                                    VerticalAlignment="Center"
                                    Foreground="DarkGray"
                                    Text="{Binding ElemId, StringFormat=(id: {0})}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn
                    Width="450"
                    Binding="{Binding ParamValue}"
                    Header="{StaticResource DataColumnElementParamValueHeader}"
                    IsReadOnly="True" />
            </DataGrid.Columns>
        </ui:DataGrid>
        
        
        <StackPanel
            Grid.Row="5"
            Orientation="Horizontal"
            HorizontalAlignment="Right">
            <ui:TextBlock
                Margin="10"
                Foreground="Orange"
                VerticalAlignment="Center"
                Text="{Binding ErrorText}" />

            <ui:Button
                Margin="10"
                Width="150"
                Appearance="Info"
                Content="{me:LocalizationSource MainWindow.ButtonOk}"
                Click="ButtonOk_Click"
                Command="{Binding AcceptViewCommand}" />

            <ui:Button
                Margin="10"
                Width="150"
                Content="{me:LocalizationSource MainWindow.ButtonCancel}"
                IsCancel="True"
                Click="ButtonCancel_Click" />
        </StackPanel>
    </Grid>
</core:WpfUIPlatformWindow>
