<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:c="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
    xmlns:local="clr-namespace:RevitPackageDocumentation.Views"
    xmlns:controls="clr-namespace:RevitPackageDocumentation.Views.Controls"
    xmlns:s="clr-namespace:RevitPackageDocumentation.ViewModels.Configuration.Sheet"
    xmlns:sc="clr-namespace:RevitPackageDocumentation.ViewModels.Configuration.Sheet.SheetComponents">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary
            Source="CustomStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--PlanView-->
    <DataTemplate
        x:Key="PlanViewDerivedTemplate" >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Grid.Row="0"
                Margin="5"
                VerticalAlignment="Center"
                Text="Имя вида" />
            
            <TextBox
                Grid.Column="1"
                Grid.Row="0"
                Margin="5"
                Text="{Binding Path=ViewName}" />

            <TextBlock
                Grid.Column="0"
                Grid.Row="1"
                Margin="5"
                VerticalAlignment="Center"
                Text="Типоразмер вида" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="1"
                Margin="5"
                ItemsSource="{Binding DataContext.StructuralPlanViewFamilyTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding ViewFamilyType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

            <TextBlock
                Grid.Column="0"
                Grid.Row="2"
                Margin="5"
                VerticalAlignment="Center"
                Text="Типоразмер видового экрана" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="2"
                Margin="5"
                ItemsSource="{Binding DataContext.ViewportTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding ViewportType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

            <TextBlock
                Grid.Column="0"
                Grid.Row="3"
                Margin="5"
                VerticalAlignment="Center"
                Text="Шаблон вида" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="3"
                Margin="5"
                ItemsSource="{Binding DataContext.PlanViewTemplates, RelativeSource={RelativeSource AncestorType=Window}}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding ViewTemplate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

            <TextBlock
                Grid.Column="0"
                Grid.Row="4"
                Margin="5"
                VerticalAlignment="Center"
                Text="Количество" />

            <TextBox
                Grid.Column="1"
                Grid.Row="4"
                Margin="5"
                Text="{Binding Path=ViewCount}"
                IsEnabled="False"/>
            
        </Grid>
    </DataTemplate>

    <DataTemplate
        DataType="{x:Type sc:PlanViewVM}">
        <controls:SheetComponentItemControl
            DerivedTemplate="{StaticResource PlanViewDerivedTemplate}" />
    </DataTemplate>

    
    <!--SectionView-->
    <DataTemplate
        x:Key="SectionViewDerivedTemplate" >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Grid.Row="0"
                Margin="5"
                VerticalAlignment="Center"
                Text="Имя вида" />
            
            <TextBox
                Grid.Column="1"
                Grid.Row="0"
                Margin="5"
                Text="{Binding Path=ViewName}" />

            <TextBlock
                Grid.Column="0"
                Grid.Row="1"
                Margin="5"
                VerticalAlignment="Center"
                Text="Типоразмер вида" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="1"
                Margin="5"
                ItemsSource="{Binding DataContext.SectionViewFamilyTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding ViewFamilyType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

            <TextBlock
                Grid.Column="0"
                Grid.Row="2"
                Margin="5"
                VerticalAlignment="Center"
                Text="Типоразмер видового экрана" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="2"
                Margin="5"
                ItemsSource="{Binding DataContext.ViewportTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding ViewportType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

            <TextBlock
                Grid.Column="0"
                Grid.Row="3"
                Margin="5"
                VerticalAlignment="Center"
                Text="Шаблон вида" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="3"
                Margin="5"
                ItemsSource="{Binding DataContext.SectionViewTemplates, RelativeSource={RelativeSource AncestorType=Window}}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding ViewTemplate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

            <TextBlock
                Grid.Column="0"
                Grid.Row="4"
                Margin="5"
                VerticalAlignment="Center"
                Text="Количество" />

            <TextBox
                Grid.Column="1"
                Grid.Row="4"
                Margin="5"
                Text="{Binding Path=ViewCount}"
                IsEnabled="False"/>
        </Grid>
    </DataTemplate>

    <DataTemplate
        DataType="{x:Type sc:SectionViewVM}">
        <controls:SheetComponentItemControl
            DerivedTemplate="{StaticResource SectionViewDerivedTemplate}" />
    </DataTemplate>


    <!--ScheduleView-->
    <DataTemplate
        x:Key="ScheduleViewDerivedTemplate">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Grid.Row="0"
                Margin="5"
                VerticalAlignment="Center"
                Text="Имя исходной" />

            <TextBox
                Grid.Column="1"
                Grid.Row="0"
                Margin="5"
                Text="{Binding Path=ReferenceViewName}" />

            <TextBlock
                Grid.Column="0"
                Grid.Row="1"
                Margin="5"
                Text="Имя итоговой" />

            <TextBox
                Grid.Column="1"
                Grid.Row="1"
                Margin="5"
                VerticalAlignment="Center"
                Text="{Binding Path=ViewName}" />

            <TextBlock
                Grid.Column="0"
                Grid.Row="2"
                Margin="5"
                VerticalAlignment="Center"
                Text="Ряд размещения" />

            <TextBox
                Grid.Column="1"
                Grid.Row="2"
                Margin="5"
                Text="{Binding Path=ViewColumn}" />

            <TextBlock
                Grid.Column="0"
                Grid.Row="3"
                Margin="5"
                VerticalAlignment="Center"
                Text="Количество" />

            <TextBox
                Grid.Column="1"
                Grid.Row="3"
                Margin="5"
                Text="{Binding Path=ViewCount}"
                IsEnabled="False" />
        </Grid>
    </DataTemplate>

    <DataTemplate
        DataType="{x:Type sc:ScheduleViewVM}">
        <controls:SheetComponentItemControl
            DerivedTemplate="{StaticResource ScheduleViewDerivedTemplate}" />
    </DataTemplate>


    <!--TextNote-->
    <DataTemplate
        x:Key="TextNoteDerivedTemplate">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Grid.Row="0"
                Margin="5"
                VerticalAlignment="Center"
                Text="Типоразмер текста" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="0"
                Margin="5"
                ItemsSource="{Binding DataContext.TextNoteTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding TextNoteType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
            

            <TextBlock
                Grid.Column="0"
                Grid.Row="1"
                Margin="5"
                VerticalAlignment="Center"
                Text="Шаблон текста" />

            <TextBox
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Grid.Row="2"
                Margin="5"
                Text="{Binding Path=Text}" />
        </Grid>
    </DataTemplate>

    <DataTemplate
        DataType="{x:Type sc:TextNoteVM}">
        <controls:SheetComponentItemControl
            DerivedTemplate="{StaticResource TextNoteDerivedTemplate}" />
    </DataTemplate>


    <!--TypicalAnnotation-->
    <DataTemplate
        x:Key="TypicalAnnotationDerivedTemplate">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Grid.Row="0"
                Margin="5"
                VerticalAlignment="Center"
                Text="Семейство" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="0"
                Margin="5"
                ItemsSource="{Binding DataContext.GenericAnnotationFamilies, RelativeSource={RelativeSource AncestorType=Window}}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding AnnotationFamily, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" >
                <i:Interaction.Triggers>
                    <i:EventTrigger
                        EventName="SelectionChanged">
                        <i:InvokeCommandAction
                            Command="{Binding SelectAnnotationFamilyCommand}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </ComboBox>

            <TextBlock
                Grid.Column="0"
                Grid.Row="1"
                Margin="5"
                VerticalAlignment="Center"
                Text="Типоразмер" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="1"
                Margin="5"
                ItemsSource="{Binding AnnotationTypes, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding AnnotationType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
        </Grid>
    </DataTemplate>

    <DataTemplate
        DataType="{x:Type sc:TypicalAnnotationVM}">
        <controls:SheetComponentItemControl
            DerivedTemplate="{StaticResource TypicalAnnotationDerivedTemplate}" />
    </DataTemplate>

    <!--LegendView-->
    <DataTemplate
        x:Key="LegendViewDerivedTemplate">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Grid.Row="0"
                Margin="5"
                VerticalAlignment="Center"
                Text="Имя" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="0"
                Margin="5"
                ItemsSource="{Binding DataContext.LegendsInProject, RelativeSource={RelativeSource AncestorType=Window}}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding LegendView, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
        </Grid>
    </DataTemplate>

    <DataTemplate
        DataType="{x:Type sc:LegendViewVM}">
        <controls:SheetComponentItemControl
            DerivedTemplate="{StaticResource LegendViewDerivedTemplate}" />
    </DataTemplate>

    
    <DataTemplate
        DataType="{x:Type s:SheetVM}">
        <controls:SheetItemControl />
    </DataTemplate>
</ResourceDictionary>