<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:c="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
    xmlns:filters="clr-namespace:RevitPackageDocumentation.ViewModels.ScheduleFilters"
    xmlns:local="clr-namespace:RevitPackageDocumentation.Views"
    xmlns:controls="clr-namespace:RevitPackageDocumentation.Views.Controls"
    xmlns:s="clr-namespace:RevitPackageDocumentation.ViewModels.Configuration.Sheet"
    xmlns:sc="clr-namespace:RevitPackageDocumentation.ViewModels.Configuration.Sheet.SheetComponents"
    xmlns:pp="clr-namespace:RevitPackageDocumentation.ViewModels.Parameters">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary
            Source="CustomStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--StructuralPlanView-->
    <DataTemplate
        x:Key="StructuralPlanViewDerivedTemplate" >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Grid.Row="0"
                Margin="5"
                VerticalAlignment="Center"
                Text="Имя вида" />

            <controls:FormulaTextBoxControl
                Grid.Column="1"
                Grid.Row="0"
                PropFormula="{Binding Path=ViewNameFormula, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                PropResult="{Binding Path=ViewName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                UpdateCommand="{Binding PropUpdateByFormulaCommand}" />

            <TextBlock
                Grid.Column="0"
                Grid.Row="1"
                Margin="5"
                VerticalAlignment="Center"
                Text="Типоразмер вида" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="1"
                Margin="5"
                ItemsSource="{Binding DataContext.StructuralPlanViewFamilyTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding ViewFamilyType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

            <TextBlock
                Grid.Column="0"
                Grid.Row="2"
                Margin="5"
                VerticalAlignment="Center"
                Text="Типоразмер видового экрана" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="2"
                Margin="5"
                ItemsSource="{Binding DataContext.ViewportTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding ViewportType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

            <TextBlock
                Grid.Column="0"
                Grid.Row="3"
                Margin="5"
                VerticalAlignment="Center"
                Text="Шаблон вида" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="3"
                Margin="5"
                ItemsSource="{Binding DataContext.PlanViewTemplates, RelativeSource={RelativeSource AncestorType=Window}}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding ViewTemplate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

            <TextBlock
                Grid.Column="0"
                Grid.Row="4"
                Margin="5"
                VerticalAlignment="Center"
                Text="Количество" />

            <ui:NumberBox
                Grid.Column="1"
                Grid.Row="4"
                Margin="5"
                Text="{Binding Path=ViewCount, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                IsEnabled="False"/>

            <TextBlock
                Grid.Column="0"
                Grid.Row="5"
                Margin="5"
                VerticalAlignment="Center"
                Text="Привязка к объекту" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="5"
                Margin="5"
                ItemsSource="{Binding DataContext.CurrentSheetSet.SelectElemParams, RelativeSource={RelativeSource AncestorType=Window}}"
                DisplayMemberPath="ParamName"
                SelectedItem="{Binding SelectedSelectElemParam, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
        </Grid>
    </DataTemplate>

    <DataTemplate
        DataType="{x:Type sc:StructuralPlanViewVM}">
        <controls:SheetComponentItemControl
            DerivedTemplate="{StaticResource StructuralPlanViewDerivedTemplate}" />
    </DataTemplate>


