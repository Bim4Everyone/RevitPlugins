<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:c="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
    xmlns:local="clr-namespace:RevitPackageDocumentation.Views"
    xmlns:controls="clr-namespace:RevitPackageDocumentation.Views.Controls"
    xmlns:s="clr-namespace:RevitPackageDocumentation.ViewModels.Configuration.Sheet"
    xmlns:sc="clr-namespace:RevitPackageDocumentation.ViewModels.Configuration.Sheet.SheetComponents">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary
            Source="CustomStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <DataTemplate
        x:Key="PlanViewDerivedTemplate">
        <StackPanel>
            <TextBlock
                Text="Тип: План" />
        </StackPanel>
    </DataTemplate>

    <DataTemplate
        DataType="{x:Type sc:PlanViewVM}">
        <controls:SheetComponentItemControl
            DerivedTemplate="{StaticResource PlanViewDerivedTemplate}" />
    </DataTemplate>

    <DataTemplate
        x:Key="ScheduleViewDerivedTemplate">
        <StackPanel>
            <TextBlock
                Text="Тип: Schedule" />
        </StackPanel>
    </DataTemplate>

    <DataTemplate
        DataType="{x:Type sc:ScheduleViewVM}">
        <controls:SheetComponentItemControl
            DerivedTemplate="{StaticResource ScheduleViewDerivedTemplate}" />
    </DataTemplate>

    <DataTemplate
        DataType="{x:Type s:SheetVM}">
        <controls:SheetItemControl />
    </DataTemplate>
</ResourceDictionary>