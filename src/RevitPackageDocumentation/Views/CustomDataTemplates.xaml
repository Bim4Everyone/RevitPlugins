    <DataTemplate
        DataType="{x:Type s:SheetVM}">
        <controls:SheetItemControl />
    </DataTemplate>


    <!--StringParam-->
    <DataTemplate
        x:Key="StringParamDerivedTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:TextBox
                Margin="2 0"
                VerticalAlignment="Center"
                Text="{Binding Path=StringValue, UpdateSourceTrigger=PropertyChanged}">
                <i:Interaction.Triggers>
                    <i:EventTrigger
                        EventName="TextChanged">
                        <i:InvokeCommandAction
                            Command="{Binding ParamValueChangeCommand}"
                            CommandParameter="{Binding}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </ui:TextBox>
        </Grid>
    </DataTemplate>

    <DataTemplate
        DataType="{x:Type pp:StringParamVM}">
        <controls:ParamItemControl
            DerivedTemplate="{StaticResource StringParamDerivedTemplate}" />
    </DataTemplate>

    <!--SelectElemParam-->
    <DataTemplate
        x:Key="SelectElemParamDerivedTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button
                Margin="2 0"
                Content="Выбрать"
                Command="{Binding 
                    Path=DataContext.SelectElemForParamCommand, 
                    RelativeSource={RelativeSource AncestorType=Window}}"
                CommandParameter="{Binding}" />
        </Grid>
    </DataTemplate>

    <DataTemplate
        DataType="{x:Type pp:SelectElemParamVM}">
        <controls:ParamItemControl
            DerivedTemplate="{StaticResource SelectElemParamDerivedTemplate}" />
    </DataTemplate>
</ResourceDictionary>