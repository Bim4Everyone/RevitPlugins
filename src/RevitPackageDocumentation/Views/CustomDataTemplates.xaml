    <!--ScheduleView-->
    <DataTemplate
        x:Key="ScheduleViewDerivedTemplate">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Grid.Row="0"
                Margin="5"
                VerticalAlignment="Center"
                Text="Имя исходной" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="0"
                Margin="5"
                ItemsSource="{Binding DataContext.SpecsInPj, RelativeSource={RelativeSource AncestorType=Window}}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding ReferenceSpec, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                <i:Interaction.Triggers>
                    <i:EventTrigger
                        EventName="SelectionChanged">
                        <i:InvokeCommandAction
                            Command="{Binding SelectReferenceSpecCommand}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </ComboBox>

            <TextBlock
                Grid.Column="0"
                Grid.Row="1"
                Margin="5"
                VerticalAlignment="Center"
                Text="Имя итоговой" />

            <controls:FormulaTextBoxControl
                Grid.Column="1"
                Grid.Row="1"
                PropFormula="{Binding Path=ViewNameFormula, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                PropResult="{Binding Path=ViewName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                UpdateCommand="{Binding PropUpdateByFormulaCommand}" />

            <TextBlock
                Grid.Column="0"
                Grid.Row="2"
                Margin="5"
                VerticalAlignment="Center"
                Text="Ряд размещения" />

            <ui:NumberBox
                Grid.Column="1"
                Grid.Row="2"
                Margin="5"
                Text="{Binding Path=ViewColumn, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

            <TextBlock
                Grid.Column="0"
                Grid.Row="3"
                Margin="5"
                VerticalAlignment="Center"
                Text="Количество" />

            <ui:NumberBox
                Grid.Column="1"
                Grid.Row="3"
                Margin="5"
                Text="{Binding Path=ViewCount, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                IsEnabled="False" />

            <Border
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Grid.Row="4"
                Margin="5"
                Style="{StaticResource CustomBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ui:TextBlock
                        Grid.Row="0"
                        Margin="5 0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Text="Фильтры" />

                    <ui:Button
                        Grid.Row="0"
                        HorizontalAlignment="Right"
                        Content="+"
                        Command="{Binding ScheduleFilterList.AddFilterCommand}" />

                    <ItemsControl
                        Grid.Row="1"
                        HorizontalContentAlignment="Stretch"
                        ItemsSource="{Binding Path=ScheduleFilterList.ScheduleFilterRules, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                </Grid>
            </Border>
        </Grid>
    </DataTemplate>

    <DataTemplate
        DataType="{x:Type sc:ScheduleViewVM}">
        <controls:SheetComponentItemControl
            DerivedTemplate="{StaticResource ScheduleViewDerivedTemplate}" />
    </DataTemplate>

    <DataTemplate
        DataType="{x:Type filters:ScheduleFilterRuleVM}">
        <controls:SpecFilterItemControl />
    </DataTemplate>


    <!--TextNote-->
    <DataTemplate
        x:Key="TextNoteDerivedTemplate">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Grid.Row="0"
                Margin="5"
                VerticalAlignment="Center"
                Text="Типоразмер текста" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="0"
                Margin="5"
                ItemsSource="{Binding DataContext.TextNoteTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding TextNoteType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
            

            <TextBlock
                Grid.Column="0"
                Grid.Row="1"
                Margin="5"
                VerticalAlignment="Center"
                Text="Шаблон текста" />

            <controls:FormulaTextBoxControl
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Grid.Row="2"
                PropFormula="{Binding Path=TextFormula, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                PropResult="{Binding Path=Text, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                UpdateCommand="{Binding PropUpdateByFormulaCommand}" />
        </Grid>
    </DataTemplate>

    <DataTemplate
        DataType="{x:Type sc:TextNoteVM}">
        <controls:SheetComponentItemControl
            DerivedTemplate="{StaticResource TextNoteDerivedTemplate}" />
    </DataTemplate>


    <!--TypicalAnnotation-->
    <DataTemplate
        x:Key="TypicalAnnotationDerivedTemplate">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Grid.Row="0"
                Margin="5"
                VerticalAlignment="Center"
                Text="Семейство" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="0"
                Margin="5"
                ItemsSource="{Binding DataContext.GenericAnnotationFamilies, RelativeSource={RelativeSource AncestorType=Window}}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding AnnotationFamily, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" >
                <i:Interaction.Triggers>
                    <i:EventTrigger
                        EventName="SelectionChanged">
                        <i:InvokeCommandAction
                            Command="{Binding SelectAnnotationFamilyCommand}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </ComboBox>

            <TextBlock
                Grid.Column="0"
                Grid.Row="1"
                Margin="5"
                VerticalAlignment="Center"
                Text="Типоразмер" />

            <ComboBox
                Grid.Column="1"
                Grid.Row="1"
                Margin="5"
                ItemsSource="{Binding AnnotationTypes, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding AnnotationType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
        </Grid>
    </DataTemplate>

    <DataTemplate
        DataType="{x:Type sc:TypicalAnnotationVM}">
        <controls:SheetComponentItemControl
            DerivedTemplate="{StaticResource TypicalAnnotationDerivedTemplate}" />
    </DataTemplate>

