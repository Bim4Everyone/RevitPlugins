<UserControl
    x:Class="RevitPackageDocumentation.Views.Controls.ParamItemControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:pp="clr-namespace:RevitPackageDocumentation.ViewModels.Parameters"
    xmlns:local="clr-namespace:RevitPackageDocumentation.Views.Controls"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=pp:PluginParamVM}"
    x:Name="root"
    d:DesignHeight="50"
    d:DesignWidth="300">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="../CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border
        Margin="5"
        Style="{StaticResource CustomBorder}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:TextBox
                Grid.Column="0"
                Margin="2 0"
                MinWidth="40"
                VerticalAlignment="Center"
                Text="{Binding Path=ParamName}"/>

            <ContentControl
                Grid.Column="1"
                Grid.Row="0"
                Content="{Binding}"
                ContentTemplate="{Binding DerivedTemplate, ElementName=root}" />

            <ui:Button
                x:Name="DeleteButton"
                Grid.Column="2"
                Margin="2 0"
                Content="✕"
                Appearance="Danger"
                Command="{Binding
                    Path=DataContext.RemoveSheetSetParamCommand, 
                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                CommandParameter="{Binding}">
            </ui:Button>
        </Grid>
    </Border>
</UserControl>