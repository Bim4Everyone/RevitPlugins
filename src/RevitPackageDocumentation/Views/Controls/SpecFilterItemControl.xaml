<UserControl
    x:Class="RevitPackageDocumentation.Views.Controls.SpecFilterItemControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:sheet="clr-namespace:RevitPackageDocumentation.ViewModels.Configuration.Sheet"
    xmlns:filters="clr-namespace:RevitPackageDocumentation.ViewModels.ScheduleFilters"
    xmlns:converters="clr-namespace:dosymep.WPF.Converters"
    xmlns:controls="clr-namespace:RevitPackageDocumentation.Views.Controls"
    
    d:DataContext="{d:DesignInstance Type=filters:ScheduleFilterRuleVM}"
    mc:Ignorable="d"
    d:DesignHeight="50"
    d:DesignWidth="400">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="../CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ui:Button
            Grid.Column="0"
            Margin="0 7"
            VerticalAlignment="Top"
            Appearance="Danger"
            Content="✕"
            Command="{Binding Path=ScheduleFilterList.RemoveFilterCommand}"
            CommandParameter="{Binding}"/>

        <ComboBox
            Grid.Column="1"
            Margin="5"
            VerticalAlignment="Top"
            DisplayMemberPath="FieldName"
            ItemsSource="{Binding ScheduleFilterList.SelectedScheduleFields, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
            SelectedItem="{Binding SelectedSpecField, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
            <i:Interaction.Triggers>
                <i:EventTrigger
                    EventName="SelectionChanged">
                    <i:InvokeCommandAction
                        Command="{Binding SelectSpecFieldCommand}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </ComboBox>

        <ComboBox
            Grid.Column="2"
            Margin="5"
            VerticalAlignment="Top"
            DisplayMemberPath="Name"
            ItemsSource="{Binding 
                Path=DataContext.FilterTypes, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay,
                RelativeSource={RelativeSource AncestorType=Window}}"
            SelectedItem="{Binding SelectedFilterType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

        <controls:FormulaTextBoxControl
            Grid.Column="3"
            Margin="0 5"
            PropFormula="{Binding Path=FilterValueFormula, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
            PropResult="{Binding Path=FilterValue, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
            UpdateCommand="{Binding Path=PropUpdateByFormulaCommand}" />
    </Grid>
</UserControl>
