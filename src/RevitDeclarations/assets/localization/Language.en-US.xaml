    <system:String x:Key="ToolTip.GroupBySectionParamApartToolTip">
        Parameter used to group rooms by sections. If rooms have the same 
        value of this parameter, they are considered to belong to the same section.
    </system:String>
    <system:String x:Key="ToolTip.GroupBySectionParamComToolTip">
        Parameter used to group non-residential rooms into main groups.
        Within these groups, additional grouping is performed by the next parameter.
    </system:String>
    <system:String x:Key="ToolTip.GroupBySectionParamPublicToolTip">
        Parameter used to group rooms by sections.
        If rooms have the same value of this parameter, they are considered to belong to the same section.
    </system:String>
    <system:String x:Key="ToolTip.GroupByGroupApartParamToolTip">
        Parameter used to group rooms by apartments.
        If rooms on the same level have the same value of this parameter
        and belong to the same section, they are considered to belong to the same apartment.
    </system:String>
    <system:String x:Key="ToolTip.GroupByGroupComParamToolTip">
        Parameter used to group rooms within main groups.
        Rooms grouped by this parameter are merged into a single row in the declaration.
    </system:String>
    <system:String x:Key="ToolTip.MultiStoreyApartParamToolTip">
        Parameter used to identify duplex apartments. All rooms 
        with the same value of this parameter are considered one apartment, 
        even if they are located on different levels. For single-level apartments, the parameter may be left empty.
    </system:String>
    <system:String x:Key="ToolTip.MultiStoreyComParamToolTip">
        Parameter used to identify multi-level groups. All rooms 
        with the same value of this parameter are considered one group, even if they 
        are located on different levels. For single-level groups, the parameter may be left empty.
    </system:String>
