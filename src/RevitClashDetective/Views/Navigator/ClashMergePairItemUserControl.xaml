<UserControl
    x:Class="RevitClashDetective.Views.Navigator.ClashMergePairItemUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:RevitClashDetective.Views.Navigator"
    xmlns:vm="clr-namespace:RevitClashDetective.ViewModels.Navigator"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:m="clr-namespace:RevitClashDetective.Models.Clashes"
    xmlns:converters="clr-namespace:dosymep.WpfCore.Converters;assembly=dosymep.WpfCore"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="300"
    x:Name="_this"
    d:DataContext="{d:DesignInstance vm:ClashViewModel, IsDesignTimeCreatable=False}">
    <!-- UserControl для отображения варианта коллизии (существующий/импортируемый) в окне мержа отчетов -->
    <UserControl.Resources>
        <converters:ObjectToObjectConverter
            x:Key="ClashStatusToImageConverter">
            <converters:CoupleItem
                Source="{x:Static m:ClashStatus.Active}"
                Target="pack://application:,,,/DevExpress.Images.v21.2;component/Images/XAF/State_Priority_High.png" />
            <converters:CoupleItem
                Source="{x:Static m:ClashStatus.Analized}"
                Target="pack://application:,,,/DevExpress.Images.v21.2;component/Images/XAF/State_Priority_Low.png" />
            <converters:CoupleItem
                Source="{x:Static m:ClashStatus.Solved}"
                Target="pack://application:,,,/DevExpress.Images.v21.2;component/Images/XAF/State_Priority_Normal.png" />
        </converters:ObjectToObjectConverter>
    </UserControl.Resources>
    <StackPanel>
        <DockPanel>
            <CheckBox
                IsChecked="{Binding ItemIsSelected, ElementName=_this}" />
            <Label
                VerticalAlignment="Center"
                Content="{Binding Title, ElementName=_this}" />
        </DockPanel>
        <DockPanel
            Margin="0 4">
            <Label
                DockPanel.Dock="Top"
                Content="Название" />
            <CheckBox
                DockPanel.Dock="Left"
                IsChecked="{Binding ItemNameIsSelected, ElementName=_this}" />
            <TextBlock
                DockPanel.Dock="Left"
                VerticalAlignment="Center"
                Text="{Binding ClashName}" />
        </DockPanel>
        <DockPanel
            Margin="0 4">
            <Label
                DockPanel.Dock="Top"
                Content="Статус" />
            <CheckBox
                DockPanel.Dock="Left"
                IsChecked="{Binding ItemStatusIsSelected, ElementName=_this}" />
            <Image
                DockPanel.Dock="Left"
                Width="16"
                Height="16"
                Source="{Binding ClashStatus, Converter={StaticResource ClashStatusToImageConverter}}"
                Margin="0 0 4 0" />
            <TextBlock
                DockPanel.Dock="Left"
                VerticalAlignment="Center"
                Text="{Binding ClashStatus}" />
        </DockPanel>
        <DockPanel>
            <Label
                DockPanel.Dock="Top"
                Content="Комментарии" />
            <CheckBox
                DockPanel.Dock="Left"
                IsChecked="{Binding ItemCommentsIsSelected, ElementName=_this}" />
            <dx:SimpleButton
                DockPanel.Dock="Left"
                HorizontalAlignment="Left"
                Content="{Binding Comments.Count}"
                Command="{Binding ShowCommentsCommand, ElementName=_this}"
                Glyph="{dx:DXImage 'Images/Comments/ShowHideComment_16x16.png'}"
                CommandParameter="{Binding}" />
        </DockPanel>
    </StackPanel>
</UserControl>