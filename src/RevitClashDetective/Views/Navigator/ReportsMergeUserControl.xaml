<UserControl
    x:Class="RevitClashDetective.Views.Navigator.ReportsMergeUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:RevitClashDetective.Views.Navigator"
    xmlns:vm="clr-namespace:RevitClashDetective.ViewModels.Navigator"
    xmlns:dxi="http://schemas.devexpress.com/winfx/2008/xaml/core/internal"
    xmlns:dxt="http://schemas.devexpress.com/winfx/2008/xaml/core/themekeys"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="300"
    x:ClassModifier="internal"
    x:Name="_this"
    d:DataContext="{d:DesignInstance vm:ReportsMergeViewModel, IsDesignTimeCreatable=False}">
    <UserControl.Resources>
        <Style
            TargetType="Border">
            <Setter
                Property="Background"
                Value="{dxi:ThemeResource {dxt:PaletteBrushThemeKey ResourceKey=Backstage.Background}}" />
            <Setter
                Property="BorderBrush"
                Value="{dxi:ThemeResource {dxt:PaletteBrushThemeKey ResourceKey=Border}}" />
            <Setter
                Property="BorderThickness"
                Value="1" />
            <Setter
                Property="CornerRadius"
                Value="4" />
            <Setter
                Property="Padding"
                Value="14 8" />
            <Setter
                Property="VerticalAlignment"
                Value="Stretch" />
            <Setter
                Property="HorizontalAlignment"
                Value="Stretch" />
            <Setter
                Property="ScrollViewer.HorizontalScrollBarVisibility"
                Value="Visible" />
            <Setter
                Property="ScrollViewer.VerticalScrollBarVisibility"
                Value="Visible" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition
                Height="*" />
            <RowDefinition
                Height="Auto" />
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    Width="1*"
                    MinWidth="300" />
                <ColumnDefinition
                    Width="Auto" />
                <ColumnDefinition
                    Width="2*"
                    MinWidth="300" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0">
                <DockPanel
                    LastChildFill="True">
                    <TextBlock
                        DockPanel.Dock="Top"
                        Margin="0 0 0 4"
                        Text="Отчеты, требующие внимания" />
                    <TreeView
                        SelectedItemChanged="TreeView_OnSelectedItemChanged"
                        ItemsSource="{Binding VisibleReports}">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate
                                ItemsSource="{Binding Items}">
                                <DockPanel>
                                    <TextBlock
                                        ToolTip="{Binding Name}"
                                        Text="{Binding Name}" />
                                    <TextBlock
                                        Margin="4 0 0 0"
                                        Text="{Binding ClashesCount, StringFormat='({0})'}" />
                                </DockPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <GridSplitter
                Grid.Column="1"
                Width="4"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch" />

            <Border
                Grid.Column="2">
                <local:ClashMergePairUserControl
                    DataContext="{Binding SelectedClashMergePairItem}"
                    PickElementCommand="{Binding DataContext.PickElementCommand, ElementName=_this}"
                    SelectClashCommand="{Binding SelectClashCommand, ElementName=_this}"
                    ShowCommentsCommand="{Binding ShowCommentsCommand, ElementName=_this}" />
            </Border>
        </Grid>

        <DockPanel
            Grid.Row="1"
            Margin="0 8 0 0"
            HorizontalAlignment="Right">
            <Button
                Content="ОК"
                Height="25"
                Width="80"
                Margin="10 0"
                IsCancel="true"
                CommandParameter="{Binding}"
                Command="{Binding ElementName=_this, Path= AcceptMergeCommand}" />
            <Button
                Content="Отмена"
                Height="25"
                Width="80"
                Command="{Binding ElementName=_this, Path=CancelMergeCommand}" />
        </DockPanel>
    </Grid>
</UserControl>