<UserControl
    x:Class="RevitClashDetective.Views.Navigator.ReportsMergeUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:RevitClashDetective.Views.Navigator"
    xmlns:vm="clr-namespace:RevitClashDetective.ViewModels.Navigator"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="300"
    x:ClassModifier="internal"
    x:Name="_this"
    d:DataContext="{d:DesignInstance vm:ReportsMergeViewModel, IsDesignTimeCreatable=False}">
    <UserControl.Resources>

    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition
                Height="*" />
            <RowDefinition
                Height="Auto" />
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    Width="300" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <TreeView
                Grid.Column="0"
                SelectedItemChanged="TreeView_OnSelectedItemChanged"
                ItemsSource="{Binding ReportsToMerge}">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate
                        ItemsSource="{Binding Items}">
                        <TextBlock
                            Text="{Binding Name}" />
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <local:ClashMergePairUserControl
                Grid.Column="1"
                DataContext="{Binding SelectedClashMergePairItem}"
                PickElementCommand="{Binding DataContext.PickElementCommand, ElementName=_this}"
                SelectClashCommand="{Binding SelectClashCommand, ElementName=_this}"
                ShowCommentsCommand="{Binding ShowCommentsCommand, ElementName=_this}" />
        </Grid>

        <DockPanel
            Grid.Row="1"
            Margin="0 10 0 0"
            HorizontalAlignment="Right">
            <Button
                Content="ОК"
                Height="25"
                Width="80"
                Margin="10 0"
                IsCancel="true"
                CommandParameter="{Binding}"
                Command="{Binding ElementName=_this, Path= AcceptMergeCommand}" />
            <Button
                Content="Отмена"
                Height="25"
                Width="80"
                Command="{Binding ElementName=_this, Path=CancelMergeCommand}" />
        </DockPanel>
    </Grid>
</UserControl>