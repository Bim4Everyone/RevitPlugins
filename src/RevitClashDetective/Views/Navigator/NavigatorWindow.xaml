<base:ThemedPlatformWindow
    x:Class="RevitClashDetective.Views.Navigator.NavigatorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:RevitClashDetective.ViewModels.Navigator"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:mvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:base="clr-namespace:dosymep.WPF.Views"
    xmlns:common="clr-namespace:dosymep.Xpf.Core.SimpleServices;assembly=dosymep.Xpf.Core"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:wpfbehaviors="clr-namespace:dosymep.WpfCore.Behaviors;assembly=dosymep.WpfCore"
    xmlns:navigator="clr-namespace:RevitClashDetective.Views.Navigator"
    xmlns:converters="clr-namespace:dosymep.WpfCore.Converters;assembly=dosymep.WpfCore"
    mc:Ignorable="d"
    Title="Навигатор"
    Height="450"
    Width="800"
    MinHeight="300"
    MinWidth="500"
    x:Name="_this"
    x:ClassModifier="internal"
    d:DataContext="{d:DesignInstance vm:NavigatorViewModel, IsDesignTimeCreatable=False}">
    <b:Interaction.Triggers>
        <b:EventTrigger
            EventName="Closing">
            <b:InvokeCommandAction
                Command="{Binding OpenClashDetectorCommand}" />
            <b:InvokeCommandAction
                Command="{Binding AskForSaveCommand}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>
    <b:Interaction.Behaviors>
        <wpfbehaviors:WpfAttachServiceBehavior
            AttachableService="{Binding OpenFileDialogService}" />
        <wpfbehaviors:WpfAttachServiceBehavior
            AttachableService="{Binding SaveFileDialogService}" />
    </b:Interaction.Behaviors>
    <base:ThemedPlatformWindow.Resources>
        <DataTemplate
            x:Key="CommentEditorTemplate">
            <navigator:CommentsEditorView />
        </DataTemplate>
        <converters:BoolToVisibilityConverter
            x:Key="ReportVisibilityConverter"
            TrueValue="Collapsed"
            FalseValue="Visible" />

        <converters:BoolToVisibilityConverter
            x:Key="ReportsMergeVisibilityConverter"
            TrueValue="Visible"
            FalseValue="Collapsed" />
    </base:ThemedPlatformWindow.Resources>
    <mvvm:Interaction.Behaviors>
        <dx:DialogService
            ViewTemplate="{StaticResource CommentEditorTemplate}">
            <dx:DialogService.DialogStyle>
                <Style
                    TargetType="Window">
                    <Setter
                        Property="MinHeight"
                        Value="400" />
                    <Setter
                        Property="MaxHeight"
                        Value="800" />
                    <Setter
                        Property="MinWidth"
                        Value="600" />
                    <Setter
                        Property="SizeToContent"
                        Value="WidthAndHeight" />
                    <Setter
                        Property="WindowStyle"
                        Value="ToolWindow" />
                </Style>
            </dx:DialogService.DialogStyle>
        </dx:DialogService>
        <common:AttachServiceBehavior
            AttachableService="{Binding MessageBoxService}" />
    </mvvm:Interaction.Behaviors>
    <Grid
        Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition
                Height="Auto" />
            <RowDefinition
                Height="*" />
            <RowDefinition
                Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel
            Grid.Row="0"
            LastChildFill="True"
            Visibility="{Binding ElementName=_this,
                Path=DataContext.ShowReportsMergeView, 
                Converter={StaticResource ReportVisibilityConverter}}">

            <dx:SimpleButton
                DockPanel.Dock="Left"
                ToolTip="Загрузить проверки"
                Command="{Binding LoadCommand}"
                Glyph="{dx:DXImage 'Office2013/Actions/Download_32x32.png'}" />
            <dx:SimpleButton
                DockPanel.Dock="Left"
                Margin="5 0 0 0"
                ToolTip="Сохранить все проверки"
                Command="{Binding SaveAllReportsCommand}"
                Glyph="{dx:DXImage 'Office2013/Save/SaveAll_32x32.png'}" />
            <dx:SimpleButton
                DockPanel.Dock="Left"
                Margin="5 0 0 0"
                ToolTip="Сохранить активную проверку"
                Command="{Binding SelectedReport.SaveCommand }"
                Glyph="{dx:DXImage 'DevAV/Actions/Save_32x32.png'}" />
            <dx:SimpleButton
                DockPanel.Dock="Left"
                Margin="5 0 0 0"
                ToolTip="Сохранить как активную проверку"
                Command="{Binding SelectedReport.SaveAsCommand}"
                Glyph="{dx:DXImage 'DevAV/Actions/SaveAs_32x32.png'}" />
            <dx:SimpleButton
                DockPanel.Dock="Right"
                Margin="5 0 0 0"
                ToolTip="Удалить активную проверку"
                Command="{Binding DeleteCommand}"
                Glyph="{dx:DXImage 'Images/Actions/Trash_32x32.png'}" />
            <dxe:ComboBoxEdit
                IsTextEditable="True"
                AutoComplete="True"
                IsCaseSensitiveSearch="False"
                IncrementalFiltering="True"
                ImmediatePopup="True"
                Margin="5 0 0 0"
                DisplayMember="Name"
                ItemsSource="{Binding Reports}"
                SelectedItem="{Binding SelectedReport, UpdateSourceTrigger=PropertyChanged}">
            </dxe:ComboBoxEdit>

        </DockPanel>

        <navigator:ReportUserControl
            Grid.Row="1"
            x:Name="_selectedReportView"
            SelectClashCommand="{Binding ElementName=_this, Path=DataContext.SelectClashCommand}"
            EditCommentsCommand="{Binding ElementName=_this, Path=DataContext.EditCommentsCommand}"
            DataContext="{Binding SelectedReport}"
            Visibility="{Binding ElementName=_this,
                Path=DataContext.ShowReportsMergeView, 
                Converter={StaticResource ReportVisibilityConverter}}" />

        <navigator:ReportsMergeUserControl
            Grid.Row="0"
            Grid.RowSpan="3"
            DataContext="{Binding ReportsMergeViewModel}"
            AcceptMergeCommand="{Binding ElementName=_this, Path=DataContext.AcceptReportsMergeCommand}"
            CancelMergeCommand="{Binding ElementName=_this, Path=DataContext.CancelReportsMergeCommand}"
            ShowCommentsCommand="{Binding ElementName=_this, Path=DataContext.ShowCommentsCommand}"
            SelectClashCommand="{Binding ElementName=_this, Path=DataContext.SelectClashCommand}"
            Visibility="{Binding ElementName=_this,
                Path=DataContext.ShowReportsMergeView, 
                Converter={StaticResource ReportsMergeVisibilityConverter}}" />

        <DockPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Margin="0 10 0 0"
            Visibility="{Binding ElementName=_this,
                Path=DataContext.ShowReportsMergeView, 
                Converter={StaticResource ReportVisibilityConverter}}">
            <dxe:TextEdit
                Margin="10 0"
                IsReadOnly="True"
                EditMode="InplaceActive"
                EditValue="{Binding SelectedReport.Message}"
                Foreground="Green" />
            <dx:SimpleButton
                Content="Отмена"
                Height="25"
                Width="80"
                IsCancel="true"
                Click="ButtonCancel_Click" />
        </DockPanel>

    </Grid>
</base:ThemedPlatformWindow>