<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:converters="clr-namespace:dosymep.WpfCore.Converters;assembly=dosymep.WpfCore"
    xmlns:m="clr-namespace:RevitClashDetective.Models.Clashes">
    <system:Boolean
        x:Key="True">True</system:Boolean>
    <system:Boolean
        x:Key="False">False</system:Boolean>
    <converters:ObjectToObjectConverter
        x:Key="ClashStatusToBoolConverter">
        <converters:CoupleItem
            Source="{x:Static m:ClashStatus.Active}"
            Target="{StaticResource True}" />
        <converters:CoupleItem
            Source="{x:Static m:ClashStatus.Analized}"
            Target="{StaticResource True}" />
        <converters:CoupleItem
            Source="{x:Static m:ClashStatus.Solved}"
            Target="{StaticResource True}" />
        <converters:CoupleItem
            Source="{x:Static m:ClashStatus.Imaginary}"
            Target="{StaticResource False}" />
    </converters:ObjectToObjectConverter>
    <converters:ObjectToObjectConverter
        x:Key="ClashStatusToImageConverter">
        <converters:CoupleItem
            Source="{x:Static m:ClashStatus.Active}"
            Target="pack://application:,,,/DevExpress.Images.v21.2;component/Images/XAF/State_Priority_High.png" />
        <converters:CoupleItem
            Source="{x:Static m:ClashStatus.Analized}"
            Target="pack://application:,,,/DevExpress.Images.v21.2;component/Images/XAF/State_Priority_Low.png" />
        <converters:CoupleItem
            Source="{x:Static m:ClashStatus.Solved}"
            Target="pack://application:,,,/DevExpress.Images.v21.2;component/Images/XAF/State_Priority_Normal.png" />
        <converters:CoupleItem
            Source="{x:Static m:ClashStatus.Imaginary}"
            Target="pack://application:,,,/DevExpress.Images.v21.2;component/DevAV/Actions/Delete_32x32.png" />
    </converters:ObjectToObjectConverter>
</ResourceDictionary>