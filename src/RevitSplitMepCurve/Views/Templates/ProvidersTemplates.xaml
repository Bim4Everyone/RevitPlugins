<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:RevitSplitMepCurve.ViewModels.Providers"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <DataTemplate DataType="{x:Type vm:PipesProviderViewModel}">
        <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="{Binding RoundSymbol.Label}" />
            <ComboBox
                Grid.Column="1"
                ItemsSource="{Binding RoundSymbol.AvailableItems}"
                DisplayMemberPath="Name"
                SelectedItem="{Binding RoundSymbol.SelectedItem}" />
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:DuctsProviderViewModel}">
        <StackPanel Orientation="Vertical">
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ui:TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="{Binding RoundSymbol.Label}" />
                <ComboBox
                    Grid.Column="1"
                    ItemsSource="{Binding RoundSymbol.AvailableItems}"
                    DisplayMemberPath="Name"
                    SelectedItem="{Binding RoundSymbol.SelectedItem}" />
            </Grid>
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ui:TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="{Binding RectangleSymbol.Label}" />
                <ComboBox
                    Grid.Column="1"
                    ItemsSource="{Binding RectangleSymbol.AvailableItems}"
                    DisplayMemberPath="Name"
                    SelectedItem="{Binding RectangleSymbol.SelectedItem}" />
            </Grid>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
