<core:WpfUIPlatformWindow
    x:Class="RevitSplitMepCurve.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:vms="clr-namespace:RevitSplitMepCurve.ViewModels"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:wpfbehaviors="clr-namespace:dosymep.WpfCore.Behaviors;assembly=dosymep.WpfCore"
    xmlns:core="clr-namespace:dosymep.WpfUI.Core"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:me="clr-namespace:dosymep.WpfCore.MarkupExtensions;assembly=dosymep.WpfCore"
    mc:Ignorable="d"
    Title="{me:LocalizationSource MainWindow.Title}"
    Height="640"
    Width="720"
    MinHeight="500"
    MinWidth="600"
    d:DataContext="{d:DesignInstance vms:MainViewModel, IsDesignTimeCreatable=False}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="Templates/ProvidersTemplates.xaml" />
                <ResourceDictionary
                    Source="../assets/Styles/CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style
                TargetType="Label">
                <Setter
                    Property="Margin"
                    Value="0" />
                <Setter
                    Property="VerticalAlignment"
                    Value="Center" />
                <Setter
                    Property="Focusable"
                    Value="False" />
                <Setter
                    Property="Foreground"
                    Value="{DynamicResource LabelForeground}" />
                <Setter
                    Property="SnapsToDevicePixels"
                    Value="True" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <i:Interaction.Behaviors>
        <wpfbehaviors:WpfAttachServiceBehavior
            AttachableService="{Binding MessageBoxService}" />
    </i:Interaction.Behaviors>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadViewCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="{me:LocalizationSource MainWindow.Title}" />

        <Border
            Grid.Row="1"
            Margin="8 0 8 0"
            Style="{StaticResource CustomBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition
                        Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="200" />
                    <ColumnDefinition
                        Width="*" />
                </Grid.ColumnDefinitions>

                <Label
                    Grid.Row="0"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Content="{me:LocalizationSource MainWindow.SelectionMode}" />
                <ComboBox
                    Grid.Row="0"
                    Grid.Column="1"
                    ItemsSource="{Binding AvailableSelectionModes}"
                    DisplayMemberPath="Name"
                    SelectedItem="{Binding SelectionMode}">
                </ComboBox>
            </Grid>
        </Border>

        <Border
            Grid.Row="2"
            Margin="8"
            Style="{StaticResource CustomBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition
                        Height="Auto" />
                    <RowDefinition
                        Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="200" />
                    <ColumnDefinition
                        Width="*" />
                </Grid.ColumnDefinitions>
                <Label
                    Grid.Row="0"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Content="{me:LocalizationSource MainWindow.MepClass}" />
                <ComboBox
                    Grid.Row="0"
                    Grid.Column="1"
                    ItemsSource="{Binding AvailableElementsProviders}"
                    DisplayMemberPath="Name"
                    SelectedItem="{Binding ElementsProvider}" />
                <ContentControl
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Content="{Binding ElementsProvider}" />
            </Grid>
        </Border>

        <Border
            Grid.Row="3"
            Margin="8 0 8 0"
            Style="{StaticResource CustomBorder}">
            <DockPanel>
                <Label
                    DockPanel.Dock="Top"
                    Content="{me:LocalizationSource MainWindow.Levels}" />
                <CheckBox
                    DockPanel.Dock="Top"
                    Margin="5 0 0 0"
                    Content="{me:LocalizationSource MainWindow.SelectAll}"
                    IsChecked="{Binding SelectAllLevels}" />
                <ui:ListView
                    ToolTip="{me:LocalizationSource MainWindow.Levels.ElevationTooltip}"
                    ItemsSource="{Binding Levels}">
                    <ui:ListView.ItemTemplate>
                        <DataTemplate>
                            <CheckBox
                                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                Content="{Binding DisplayName}" />
                        </DataTemplate>
                    </ui:ListView.ItemTemplate>
                </ui:ListView>
            </DockPanel>
        </Border>

        <DockPanel
            Grid.Row="4">
            <ui:ToggleSwitch
                Margin="8"
                DockPanel.Dock="Left"
                Content="{me:LocalizationSource MainWindow.ShowSplitErrors}"
                IsChecked="{Binding ShowPlacingErrors}" />

            <StackPanel
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                DockPanel.Dock="Right">
                <ui:TextBlock
                    Margin="8"
                    Style="{StaticResource CustomErrorText}"
                    Text="{Binding ErrorText}" />

                <ui:Button
                    Margin="8"
                    Width="80"
                    Appearance="Info"
                    Content="{me:LocalizationSource MainWindow.ButtonOk}"
                    Click="ButtonOk_Click"
                    Command="{Binding AcceptViewCommand}" />

                <ui:Button
                    Margin="8"
                    Width="80"
                    Content="{me:LocalizationSource MainWindow.ButtonCancel}"
                    IsCancel="True"
                    Click="ButtonCancel_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</core:WpfUIPlatformWindow>
